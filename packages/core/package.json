{
  "name": "node-excellent-migrations",
  "version": "0.1.0",
  "description": "Detect dangerous operations in database migrations and run them safely",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "node-excellent-migrations": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "pg": "^8.20.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "migration",
    "migrations",
    "database",
    "postgres",
    "postgresql",
    "safety",
    "schema",
    "sql",
    "cli",
    "linter"
  ],
  "author": "matheus1lva",
  "license": "MIT",
  "homepage": "https://github.com/matheus1lva/node-excellent-migrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matheus1lva/node-excellent-migrations.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/matheus1lva/node-excellent-migrations/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
